{
  "name": "ifont",
  "repository": "github:fabiospampinato/ifont",
  "description": "An isomorphic icon font generator with support for ligatures.",
  "license": "MIT",
  "version": "2.1.0",
  "type": "module",
  "sideEffects": false,
  "bin": "dist/bin.js",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "benchmark": "tsex benchmark",
    "benchmark:watch": "tsex benchmark --watch",
    "clean": "tsex clean",
    "compile": "tsex compile",
    "compile:watch": "tsex compile --watch",
    "test": "npm run test:supported && npm run test:unsupported",
    "test:supported": "node dist/bin.js preview -i test/icons_supported/*.svg",
    "test:unsupported": "node dist/bin.js preview -i test/icons_unsupported/*.svg",
    "prepublishOnly": "tsex prepare"
  },
  "keywords": [
    "icon",
    "font",
    "generator",
    "isomorphic",
    "ttf",
    "ligatures"
  ],
  "dependencies": {
    "cubic2quad": "^1.2.1",
    "radix64-encoding": "^2.0.2",
    "specialist": "^2.0.0",
    "svgpath": "^2.6.0",
    "tiny-open": "^1.3.0",
    "xml-simple-parser": "^1.0.2",
    "zeptoid": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "benchloop": "^2.1.1",
    "tsex": "^4.0.2",
    "typescript": "^5.9.3"
  }
}
